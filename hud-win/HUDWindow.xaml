<Window x:Class="JarvisHUD.HUDWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jarvis"
        Width="200" Height="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>
        <!-- Outer glow -->
        <Ellipse x:Name="OuterGlow"
                 Width="144" Height="144"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Opacity="0.15">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00CED1" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="20" />
            </Ellipse.Effect>
        </Ellipse>

        <!-- Spinning ring -->
        <Ellipse x:Name="SpinRing"
                 Width="104" Height="104"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 StrokeThickness="3"
                 Visibility="Collapsed">
            <Ellipse.Stroke>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00CED1" Offset="0" />
                    <GradientStop Color="#00CED130" Offset="0.5" />
                    <GradientStop Color="#00CED1" Offset="1" />
                </LinearGradientBrush>
            </Ellipse.Stroke>
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="RingRotation" CenterX="52" CenterY="52" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Core orb -->
        <Ellipse x:Name="CoreOrb"
                 Width="80" Height="80"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop x:Name="OrbColorInner" Color="#E600CED1" Offset="0" />
                    <GradientStop x:Name="OrbColorOuter" Color="#6600CED1" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <DropShadowEffect Color="#00CED1" BlurRadius="15" ShadowDepth="0" Opacity="0.5" />
            </Ellipse.Effect>
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="OrbScale" CenterX="40" CenterY="40"
                                ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Specular highlight -->
        <Ellipse Width="56" Height="56"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Margin="-12,-12,0,0"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.35,0.35" GradientOrigin="0.35,0.35">
                    <GradientStop Color="#4DFFFFFF" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
    </Grid>
</Window>
