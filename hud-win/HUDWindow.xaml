<Window x:Class="JarvisHUD.HUDWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jarvis"
        Width="200" Height="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- ── Orb row ── -->

        <!-- Time (above orb) -->
        <TextBlock Grid.Row="0"
                   x:Name="TimeText"
                   Text="--:--"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,10,0,0"
                   FontSize="11"
                   FontFamily="Consolas"
                   FontWeight="Bold"
                   Foreground="#CC00CED1"
                   IsHitTestVisible="False" />

        <!-- Outer glow -->
        <Ellipse Grid.Row="0"
                 x:Name="OuterGlow"
                 Width="144" Height="144"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Opacity="0.15">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00CED1" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="20" />
            </Ellipse.Effect>
        </Ellipse>

        <!-- Wave ring 1 (speaking ripple) -->
        <Ellipse Grid.Row="0"
                 x:Name="WaveRing1"
                 Width="80" Height="80"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 StrokeThickness="2"
                 Visibility="Collapsed"
                 Opacity="0">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="WaveScale1" CenterX="40" CenterY="40" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Wave ring 2 (speaking ripple, staggered) -->
        <Ellipse Grid.Row="0"
                 x:Name="WaveRing2"
                 Width="80" Height="80"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 StrokeThickness="2"
                 Visibility="Collapsed"
                 Opacity="0">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="WaveScale2" CenterX="40" CenterY="40" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Spinning ring -->
        <Ellipse Grid.Row="0"
                 x:Name="SpinRing"
                 Width="104" Height="104"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 StrokeThickness="3"
                 Visibility="Collapsed">
            <Ellipse.Stroke>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00CED1" Offset="0" />
                    <GradientStop Color="#00CED130" Offset="0.5" />
                    <GradientStop Color="#00CED1" Offset="1" />
                </LinearGradientBrush>
            </Ellipse.Stroke>
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="RingRotation" CenterX="52" CenterY="52" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Core orb -->
        <Ellipse Grid.Row="0"
                 x:Name="CoreOrb"
                 Width="80" Height="80"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop x:Name="OrbColorInner" Color="#E600CED1" Offset="0" />
                    <GradientStop x:Name="OrbColorOuter" Color="#6600CED1" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <DropShadowEffect Color="#00CED1" BlurRadius="15" ShadowDepth="0" Opacity="0.5" />
            </Ellipse.Effect>
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="OrbScale" CenterX="40" CenterY="40"
                                ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Specular highlight -->
        <Ellipse Grid.Row="0"
                 Width="56" Height="56"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Margin="-12,-12,0,0"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.35,0.35" GradientOrigin="0.35,0.35">
                    <GradientStop Color="#4DFFFFFF" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ── Stats row ── -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2">

            <TextBlock x:Name="WeatherText"
                       HorizontalAlignment="Center"
                       FontSize="9"
                       FontFamily="Consolas"
                       Foreground="#9900CED1"
                       IsHitTestVisible="False" />

            <TextBlock x:Name="HealthText"
                       HorizontalAlignment="Center"
                       FontSize="9"
                       FontFamily="Consolas"
                       Foreground="#9900CED1"
                       IsHitTestVisible="False" />

            <TextBlock x:Name="TaskText"
                       HorizontalAlignment="Center"
                       FontSize="9"
                       FontFamily="Segoe UI"
                       Foreground="#7700CED1"
                       TextTrimming="CharacterEllipsis"
                       Width="180"
                       IsHitTestVisible="False" />
        </StackPanel>
    </Grid>
</Window>
